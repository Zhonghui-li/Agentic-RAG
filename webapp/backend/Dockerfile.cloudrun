FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y build-essential && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    flask==3.1.0 \
    flask-cors==5.0.0 \
    flask-pymongo==2.3.0 \
    pymongo[srv]==4.11 \
    python-dotenv==1.0.1 \
    openai==1.60.2 \
    anthropic \
    google-generativeai \
    requests==2.32.3 \
    bcrypt==4.2.1

COPY . .

EXPOSE 8080

CMD ["python", "app.py"]
