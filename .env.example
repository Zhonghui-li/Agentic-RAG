# API Keys (Required)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional API Keys (for other LLM providers)
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# MongoDB (for local development, Docker uses internal networking)
MONGO_URI=mongodb://localhost:27017/flask_database

# RAG Service URL (for local development)
RAG_SERVICE_URL=http://localhost:8001

# RAG Pipeline settings (required for reliable answers)
GEN_FORCE_ANSWER=1

# CORS: comma-separated list of allowed frontend origins.
# Leave as * for local development. Set to your hosted domain once confirmed.
# Example: ALLOWED_ORIGINS=https://aiea-lab.com,http://localhost:3000
ALLOWED_ORIGINS=*
